{
  "manifest_version": 2,
  "id": "nichengfuben.provider-deepl-adapter",
  "name": "Provider Deepl Adapter",
  "version": "1.0.0",
  "description": "deepl platform adapter plugin",
  "plugin_type": "platform",
  "author": {
    "name": "nichengfuben"
  },
  "host_application": {
    "min_version": "2.2.0-alpha",
    "max_version": "2.2.99"
  },
  "sdk": {
    "min_version": "0.3.0",
    "max_version": "0.99.99"
  },
  "dependencies": [
    "nichengfuben.provider-fncall-util"
  ],
  "capabilities": [
    "platform.adapter"
  ]
}
